quarkus.datasource.db-kind=postgresql
quarkus.datasource.username=${DB_USER}
quarkus.datasource.password=${DB_PASSWORD}
quarkus.datasource.jdbc.url=${DB_URL}
quarkus.hibernate-orm.database.generation=update


mp.jwt.verify.publickey.location=NONE
mp.jwt.verify.issuer=https://dishubosrm.acehprov.go.id
smallrye.jwt.sign.key=r7NmAExOMIt9qJiz0Hbyhf5f/lhUFcO8K4HhtSaqBHQ=
smallrye.jwt.verify.key=${smallrye.jwt.sign.key}
smallrye.jwt.verify.algorithm=HS256


app.base.url=https://dishubosrm.acehprov.go.id
app.frontend.url=https://seulamat.dishubaceh.com

# --- EMAIL ---
quarkus.mailer.host=smtp.gmail.com
quarkus.mailer.port=465
quarkus.mailer.ssl=true
quarkus.mailer.mock=false
quarkus.mailer.from=${MAIL_USERNAME}
quarkus.mailer.username=${MAIL_USERNAME}
quarkus.mailer.password=${MAIL_PASSWORD}

quarkus.http.host=0.0.0.0
quarkus.http.body.uploads-directory=/opt/mudik-v2/uploads
quarkus.http.limits.max-body-size=20M
quarkus.http.read-timeout=60s

# =============================================================
# CORS ? WAJIB ADA, PAKAI BUILT-IN QUARKUS (BUKAN CUSTOM FILTER)
# =============================================================
# Quarkus punya CORS handler di level Vert.x (lebih dalam dari JAX-RS filter).
# Ini yang paling reliable dan tidak bisa di-bypass oleh auth layer.
# Custom CorsFilter.java tetap ada sebagai backup tapi yang utama ini.
quarkus.http.cors=true
quarkus.http.cors.origins=https://seulamat.dishubaceh.com
quarkus.http.cors.methods=GET,POST,PUT,DELETE,OPTIONS,HEAD,PATCH
quarkus.http.cors.headers=origin,content-type,accept,authorization,userid,x-requested-with
quarkus.http.cors.exposed-headers=content-disposition,content-type
quarkus.http.cors.access-control-allow-credentials=true
quarkus.http.cors.access-control-max-age=24H

# =============================================================
# AUTH PERMISSIONS
# =============================================================
# proactive=false: Quarkus tidak paksa cek token di semua endpoint
quarkus.http.auth.proactive=false

# Semua /api/* boleh diakses (validasi userId dilakukan manual di kode Java)
quarkus.http.auth.permission.public.paths=/api/*
quarkus.http.auth.permission.public.policy=permit

# /api/user/* wajib token karena UserResource pakai @Authenticated
quarkus.http.auth.permission.authenticated.paths=/api/user/*
quarkus.http.auth.permission.authenticated.policy=authenticated

